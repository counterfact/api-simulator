---
import "../styles/main.css";

interface Props {
  title?: string;
  canonicalPath?: string;
}

const { title = "Counterfact — API Simulator", canonicalPath } = Astro.props;
const canonicalUrl = canonicalPath
  ? `https://counterfact.dev${canonicalPath}`
  : undefined;
const posthogApiKey =
  import.meta.env.PUBLIC_POSTHOG_API_KEY ??
  "phc_msXmBxiL8FVugNMLCx9bnPQGqfEMqmyBjnVkKhHkN3m7";
const posthogHost =
  import.meta.env.PUBLIC_POSTHOG_HOST ?? "https://us.i.posthog.com";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,400&family=Barlow:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <script is:inline define:vars={{ posthogApiKey, posthogHost }}>
      !(function (t, e) {
        let o, n, p, r;
        if (e.__SV) return;
        window.posthog = e;
        e._i = [];
        e.init = function (i, s, a) {
          function g(t, e) {
            const o = e.split(".");
            o.length === 2 && ((t = t[o[0]]), (e = o[1]));
            t[e] = function () {
              t.push([e].concat(Array.prototype.slice.call(arguments, 0)));
            };
          }
          ((p = t.createElement("script")).type = "text/javascript"),
            (p.async = !0),
            (p.src = `${posthogHost}/static/array.js`),
            (r = t.getElementsByTagName("script")[0]).parentNode?.insertBefore(
              p,
              r,
            );
          let u = e;
          void 0 !== a ? (u = e[a] = []) : (a = "posthog");
          u.people = u.people || [];
          u.toString = function (t) {
            let e = "posthog";
            return "posthog" !== a && (e += "." + a), t || (e += " (stub)"), e;
          };
          u.people.toString = function () {
            return `${u.toString(1)}.people (stub)`;
          };
          o =
            "init capture register register_once register_for_session unregister unregister_for_session reset config set_config set_person_properties set_person_properties_for_flags set_group_properties set_property_for_flags unset_property_for_flags identify alias setPersonProperties setPersonPropertiesForFlags setGroupProperties setPropertyForFlags unsetPropertyForFlags people.set people.set_once people.unset people.increment people.append people.remove people.union people.track_charge people.clear_charges people.delete_user people.setDisplayName people.set_display_name people.setPersonPropertiesOnce get_distinct_id getDistinctId get_property getProperty getSessionProperty get_session_recording_url getSessionRecordingUrl get_feature_flag getFeatureFlag get_feature_flag_payload getFeatureFlagPayload is_feature_enabled isFeatureEnabled reload_feature_flags reloadFeatureFlags updateEarlyAccessFeatureEnrollment getEarlyAccessFeatures on onFeatureFlags onSessionId registerPerson register_person parse_mode resetGroups group setPersonPropertiesForFeatureFlags startSessionRecording stopSessionRecording sessionRecordingStarted captureException loadToolbar get_surveys getSurveys renderSurvey canRenderSurvey identifyWithGroups setPersonPropertiesOnceForFlags setPersonPropertiesOnceForFlags".split(
              " ",
            );
          for (n = 0; n < o.length; n++) g(u, o[n]);
          e._i.push([i, s, a]);
        };
        e.__SV = 1;
      })(document, window.posthog || []);
      posthog.init(posthogApiKey, {
        api_host: posthogHost,
        autocapture: false,
        capture_pageview: true,
        person_profiles: "identified_only",
      });
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
